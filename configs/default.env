# pve-dedicated -- Default Configuration
# These values are used as defaults and can be overridden by CLI arguments.
# Copy this file and customize for your deployment.

# --- Provider ---
# Required (or use --provider). Auto-detected from rescue env when blank.
# Valid: hetzner | ovh
# PVE_PROVIDER=""

# --- System ---
PVE_HOSTNAME="proxmox"
PVE_FQDN="proxmox.example.com"
PVE_TIMEZONE="UTC"
PVE_EMAIL="admin@example.com"
# PVE_ROOT_PASSWORD=""       # Must be set via CLI, config file, or interactive prompt

# --- SSH Security ---
# SSH public keys for root access. When set, password login is disabled
# and SSH is hardened (PermitRootLogin prohibit-password, key-only auth).
# Multiple keys: one per line, or space-separated on one line.
# In interactive mode, keys are auto-detected from the rescue system.
# PVE_SSH_KEYS="ssh-ed25519 AAAA... user@host"

# --- Keyboard / Locale ---
PVE_KEYBOARD="en-us"
PVE_COUNTRY="us"

# --- Disk ---
PVE_DISK_MODE="auto"         # auto = use all detected disks, manual = interactive
# PVE_DISKS=""               # Comma-separated: nvme0n1,nvme1n1
PVE_FILESYSTEM="zfs"
PVE_ZFS_RAID="raid1"
PVE_ZFS_COMPRESS="lz4"
# PVE_ZFS_ASHIFT=""          # Usually auto-detected (12 for 4K, 13 for 8K)
# PVE_ZFS_ARC_MAX=""         # Max ARC memory in MiB

# --- Network ---
# PVE_INTERFACE=""           # Auto-detected if empty
PVE_NETWORK_MODE="nat"       # nat, routed, bridged
PVE_PRIVATE_SUBNET="192.168.26.0/24"
# PVE_DNS_SERVERS=""          # Provider default applied if empty
                              #   hetzner -> 185.12.64.1 185.12.64.2
                              #   ovh     -> 213.186.33.99 1.1.1.1
PVE_DNS_SERVERS="185.12.64.1 185.12.64.2"
PVE_ENABLE_DHCP=true         # Install dnsmasq DHCP on vmbr1 (NAT mode only)
                              # VMs get IPs from .100-.200 range automatically

# --- OVH-specific (only used when PVE_PROVIDER=ovh) ---
# PVE_OVH_GATEWAY_MODEL="auto"  # auto | classic | scale
# PVE_OVH_VRACK_INTERFACE=""    # Second NIC for vRack bridge (vmbr2)
# PVE_OVH_VRACK_IP_CIDR=""      # Static IP/CIDR on vRack bridge
# PVE_OVH_ADDITIONAL_IPS=""     # Comma-separated /32s for routed mode

# --- Premium: host-level LUKS (only honored in premium build) ---
# PVE_FEATURE_LUKS=false
# PVE_LUKS_PASSPHRASE=""
# PVE_LUKS_UNLOCK_MODES="passphrase"   # csv: passphrase,ssh,tpm
# PVE_LUKS_DROPBEAR_PORT="2222"
# PVE_LUKS_WAN_MAC=""

# --- Boot ---
PVE_BOOT_MODE="auto"         # auto, uefi, legacy

# --- ISO ---
# PVE_ISO_PATH=""            # Skip download if set

# --- Debian Suite ---
PVE_DEBIAN_SUITE="trixie"

# --- Logging ---
PVE_LOG_LEVEL=1              # 0=DEBUG, 1=INFO, 2=WARN, 3=ERROR
