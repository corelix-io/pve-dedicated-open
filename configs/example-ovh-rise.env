# Example: OVH Rise / Eco classic-range server (in-subnet gateway)
# Rise/Eco use a /24-style gateway in the same subnet as the server's
# main IP, e.g. main 51.255.10.42/24 with gateway 51.255.10.254.
# https://eco.ovhcloud.com/

PVE_PROVIDER="ovh"
PVE_OVH_GATEWAY_MODEL="classic"

PVE_HOSTNAME="pve-rise"
PVE_FQDN="pve-rise.example.com"
PVE_TIMEZONE="UTC"
PVE_EMAIL="ops@example.com"
PVE_ROOT_PASSWORD="CHANGE_ME_BEFORE_USE"

PVE_KEYBOARD="en-us"
PVE_COUNTRY="fr"

PVE_DISK_MODE="auto"
PVE_FILESYSTEM="zfs"
PVE_ZFS_RAID="raid1"
PVE_ZFS_COMPRESS="lz4"

# OVH default DNS (Anycast resolvers)
PVE_DNS_SERVERS="213.186.33.99 1.1.1.1"

# Network: NAT + private bridge for VMs (recommended single-IP default)
PVE_NETWORK_MODE="nat"
PVE_PRIVATE_SUBNET="192.168.50.0/24"
PVE_ENABLE_DHCP=true

PVE_BOOT_MODE="auto"
PVE_DEBIAN_SUITE="trixie"
PVE_LOG_LEVEL=1
