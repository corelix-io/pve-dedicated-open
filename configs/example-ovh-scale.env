# Example: OVH High Grade / Scale / Advance range
# These ranges use a /32 host IP with a fixed on-link gateway 100.64.0.1.
# Reference: https://help.ovhcloud.com/csm/en-gb-dedicated-servers-network-proxmox-vmac
#
# This sample uses routed mode for additional public IPs assigned to VMs.
# For each additional IP you add a route on vmbr0 (--ovh-additional-ips).

PVE_PROVIDER="ovh"
PVE_OVH_GATEWAY_MODEL="scale"

PVE_HOSTNAME="pve-hg"
PVE_FQDN="pve-hg.example.com"
PVE_TIMEZONE="UTC"
PVE_EMAIL="ops@example.com"
PVE_ROOT_PASSWORD="CHANGE_ME_BEFORE_USE"

PVE_KEYBOARD="en-us"
PVE_COUNTRY="fr"

PVE_DISK_MODE="auto"
PVE_FILESYSTEM="zfs"
PVE_ZFS_RAID="raid1"
PVE_ZFS_COMPRESS="lz4"

PVE_DNS_SERVERS="213.186.33.99 1.1.1.1"

# Routed: physical NIC keeps public IP as /32; vmbr0 bridges no ports;
# additional IPs are routed onto vmbr0 with `up ip route add ... dev vmbr0`.
PVE_NETWORK_MODE="routed"
PVE_OVH_ADDITIONAL_IPS=""   # e.g. "203.0.113.41/32, 203.0.113.42/32"

PVE_BOOT_MODE="auto"
PVE_DEBIAN_SUITE="trixie"
PVE_LOG_LEVEL=1
