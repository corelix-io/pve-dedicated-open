# Example: OVH server with vRack (private network bridge across OVH services)
# vRack uses a SECOND NIC. This sample is on a HG/Scale-range server, with
# a NAT-mode public path on vmbr0 and a vRack bridge on vmbr2.

PVE_PROVIDER="ovh"
PVE_OVH_GATEWAY_MODEL="auto"

PVE_HOSTNAME="pve-vrack"
PVE_FQDN="pve-vrack.example.com"
PVE_TIMEZONE="UTC"
PVE_EMAIL="ops@example.com"
PVE_ROOT_PASSWORD="CHANGE_ME_BEFORE_USE"

PVE_KEYBOARD="en-us"
PVE_COUNTRY="fr"

PVE_DISK_MODE="auto"
PVE_FILESYSTEM="zfs"
PVE_ZFS_RAID="raid1"
PVE_ZFS_COMPRESS="lz4"

PVE_DNS_SERVERS="213.186.33.99 1.1.1.1"

PVE_NETWORK_MODE="nat"
PVE_PRIVATE_SUBNET="192.168.60.0/24"
PVE_ENABLE_DHCP=true

# vRack second NIC + bridge IP. Set --ovh-vrack-interface to the actual
# interface name in rescue (e.g. eth1 / enp4s0f1np1) and pick a /24 inside
# the vRack subnet you allocated in the OVH Control Panel.
PVE_OVH_VRACK_INTERFACE=""        # e.g. "enp4s0f1np1"
PVE_OVH_VRACK_IP_CIDR=""          # e.g. "10.0.0.10/24"

PVE_BOOT_MODE="auto"
PVE_DEBIAN_SUITE="trixie"
PVE_LOG_LEVEL=1
